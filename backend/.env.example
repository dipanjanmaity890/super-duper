# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://fanpulse:fanpulse@localhost:5432/fanpulse_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173

# Points Config
POINTS_VOTE=10
POINTS_REACTION=5
POINTS_PREDICTION_STANDARD=50
POINTS_PREDICTION_UPSET=80
POINTS_STREAK_BONUS=25
POINTS_FIRST_VOTER_BONUS=15

# CricketData.org API (https://cricapi.com)
# Used for live match data sync (polls every 30s)
CRICKET_API_KEY=your-cricapi-key-here
